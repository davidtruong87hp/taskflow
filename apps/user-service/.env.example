PORT=4002

# These environment variables are read by the OpenTelemetry SDK automatically
# when @opentelemetry/auto-instrumentations-node is installed.
# No code needed — the SDK self-configures based on these values.
OTEL_SERVICE_NAME=user-service
OTEL_EXPORTER_OTLP_ENDPOINT=grafana.monitoring.svc.cluster.local:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_NODE_ENABLED_INSTRUMENTATIONS=http,express,nestjs-core
NODE_OPTIONS=--require @opentelemetry/auto-instrumentations-node/register