# This template is committed to git. The actual kustomization.yaml
# is generated by dev-deploy.sh and intentionally gitignored —
# it contains a build timestamp tag that changes on every local build.
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: taskflow-dev

resources:
  - ../../base

images:
  - name: taskflow/api-gateway
    newTag: local
  - name: taskflow/user-service
    newTag: local
  - name: taskflow/task-service
    newTag: local